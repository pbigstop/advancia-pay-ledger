# ── Server ──────────────────────────────────────────────
BANKING_PORT=3005
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Authentication ──────────────────────────────────────
JWT_SECRET=[YOUR_JWT_SECRET]

# ── Database ────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Crypto Treasury Keys (KEEP SECURE — use AWS KMS in production) ──
SOLANA_TREASURY_PRIVATE_KEY=[BASE58_ENCODED_SOLANA_PRIVATE_KEY]
EVM_TREASURY_PRIVATE_KEY=[HEX_PRIVATE_KEY_FOR_ETH_POLYGON_BASE]

# ── RPC Endpoints (use dedicated paid RPCs in production) ──
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
ETH_RPC_URL=https://eth.llamarpc.com
POLYGON_RPC_URL=https://polygon-rpc.com
BASE_RPC_URL=https://mainnet.base.org

# ── Withdrawal Limits ──────────────────────────────────
WITHDRAWAL_DAILY_LIMIT_USD=50000
